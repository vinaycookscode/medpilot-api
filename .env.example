# App
NODE_ENV=development
PORT=3000
APP_NAME=MedPilot API
API_PREFIX=api/v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=medpilot_user
DB_PASSWORD=
DB_NAME=medpilot_db
DB_SYNCHRONIZE=false
DB_LOGGING=true

# JWT
JWT_SECRET=
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:4200

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100
